# انسخ هذا الملف باسم .env في جذر المشروع (بجانب package.json)
# ثم عيّن القيم من لوحة Supabase: Project Settings → API

# عنوان مشروعك (مثال: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# مفتاح anon العام (ليس service_role) — يظهر في نفس صفحة API
VITE_SUPABASE_ANON_KEY=

# --- إعلان صوتي على شاشات التلفاز (النطق المحلي غالباً لا يعمل؛ الصفارة فقط) ---
# الدالة tts-announce تستخدم Microsoft Edge Read Aloud مجاناً (لا مفتاح Google).
# استدعاء TTS يستخدم VITE_SUPABASE_ANON_KEY صراحةً حتى لا يُرفض الطلب (Invalid JWT) إن بقيت جلسة أدمن منتهية على نفس المتصفح.
# انشر الدالة بعد أي تعديل عليها (بعد supabase login): npm run deploy:tts-announce أو npx supabase functions deploy tts-announce --project-ref <مرجعك>
# ثم في الواجهة (.env):
VITE_USE_EDGE_TTS=1

# خطوات أول مرة:
# 1) أنشئ مشروعاً مجانياً على https://supabase.com
# 2) SQL Editor → الصق محتوى الملف supabase/schema.sql ونفّذه
# 3) Authentication → Users → أضف مستخدمًا بريدياً
# 4) أنشئ أدمن أساسي: نفّذ supabase/seed_admin.sql بعد «Add user» في Authentication
# 5) أعد تشغيل: npm run dev
