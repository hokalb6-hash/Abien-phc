# انسخ هذا الملف باسم .env في جذر المشروع (بجانب package.json)
# ثم عيّن القيم من لوحة Supabase: Project Settings → API

# عنوان مشروعك (مثال: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# مفتاح anon العام (ليس service_role) — يظهر في نفس صفحة API
VITE_SUPABASE_ANON_KEY=

# شاشة الدور: الإعلان الصوتي يعتمد على نطق المتصفح (Web Speech) — مناسب عند توصيل لابتوب بالشاشة.
# الصفارة تعمل عبر Web Audio حتى لو تعطّل النطق على بعض الأجهزة.

# خطوات أول مرة:
# 1) أنشئ مشروعاً مجانياً على https://supabase.com
# 2) SQL Editor → الصق محتوى الملف supabase/schema.sql ونفّذه
# 3) Authentication → Users → أضف مستخدمًا بريدياً
# 4) أنشئ أدمن أساسي: نفّذ supabase/seed_admin.sql بعد «Add user» في Authentication
# 5) أعد تشغيل: npm run dev
